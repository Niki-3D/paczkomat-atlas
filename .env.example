# Database
POSTGRES_USER=paczkomat
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=paczkomat_atlas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://paczkomat:changeme_local_only@localhost:5432/paczkomat_atlas

# Production-only: least-privilege app role password (see SECRETS.md + docs/DEPLOY.md)
# POSTGRES_APP_PASSWORD=

# Backend
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
# Comma-separated origins for FastAPI CORS. Prod must NOT use "*".
CORS_ORIGINS=http://localhost:3000

# Frontend
# Code reads NEXT_PUBLIC_API_BASE_URL (see web/lib/api.ts); falls back to :8080 (Caddy).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_TILES_URL=https://tiles.paczkomat-atlas.example/poland.pmtiles

# External services
INPOST_API_URL=https://api-global-points.easypack24.net/v1
BDL_API_KEY=
EUROSTAT_API_URL=https://ec.europa.eu/eurostat/api

# Claude Code MCP (dev only — never set in production)
CONTEXT7_API_KEY=
