# Production environment template.
#
# scripts/deploy.sh copies this file to .env.production on first deploy and
# substitutes GENERATE_AT_DEPLOY_* placeholders with `openssl rand -base64
# 32`. After first deploy, edit .env.production on the SERVER ONLY — never
# commit it. The gitignore in repo root covers .env.production at every
# level.

# ---- Database (admin role) ----
POSTGRES_USER=paczkomat
POSTGRES_PASSWORD=GENERATE_AT_DEPLOY_POSTGRES_PASSWORD
POSTGRES_DB=paczkomat_atlas

# ---- Application role (least-privilege; migration 72d896bb1f4e) ----
# FastAPI connects through pgbouncer as this role. Alembic uses the admin
# role above for migrations (transactional DDL needs direct :5432).
POSTGRES_APP_USER=paczkomat_app
POSTGRES_APP_PASSWORD=GENERATE_AT_DEPLOY_APP_PASSWORD

# ---- CORS ----
# Comma-separated list. NEVER use "*" in prod.
CORS_ORIGINS=https://paczkomat-atlas.example.com

# ---- Public hostname (Caddy serves on this name) ----
PUBLIC_HOSTNAME=paczkomat-atlas.example.com

# ---- Frontend → API origin (inlined into the browser bundle) ----
NEXT_PUBLIC_API_BASE_URL=https://paczkomat-atlas.example.com

# ---- Caddy ----
# Used as the ACME account email. Required for Let's Encrypt.
TLS_EMAIL=ops@example.com

# ---- Host port bindings ----
# Defaults to 80/443. Override only if another edge proxy already owns
# those ports on the host (Case B in the deploy runbook).
EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443

# ---- Logging ----
LOG_LEVEL=INFO
